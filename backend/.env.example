# Flask
FLASK_APP=main.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=nexus_db
DB_USER=nexus_user
DB_PASSWORD=nexus_password123
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Docker database (if using Docker)
DOCKER_DB_HOST=db
DOCKER_DB_PORT=5432
DOCKER_DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DOCKER_DB_HOST}:${DOCKER_DB_PORT}/${DB_NAME}

# LLM
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=
LLM_API_KEY=
LLM_TIMEOUT=12
LLM_MAX_RETRIES=1

# SMS / Alibaba Cloud 号码认证服务
SMS_PROVIDER=mock
SMS_SIGN_NAME=速通互联验证码
SMS_TEMPLATE_CODE=100001
SMS_CODE_LENGTH=6
SMS_SEND_INTERVAL=60
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION_ID=cn-hangzhou
DYPNS_API_ENDPOINT=dypnsapi.aliyuncs.com
